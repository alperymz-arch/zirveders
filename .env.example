# Backend
SECRET_KEY=change-me-to-a-long-random-string
DATABASE_URL=postgresql+psycopg2://muhasebe:change-me@db:5432/muhasebe
CORS_ORIGINS=["http://localhost","http://localhost:5173"]
ACCOUNTING_PROVIDER=mock
ENV=production
# ACCOUNTING_PROVIDER=zirve yapıldığında ZirAPI kullanılır. API key .env'e
# YAZILMAZ — kurulumdan sonra admin panelindeki "Muhasebe Ayarları"
# ekranından (/settings) girilir ve DB'de şifreli saklanır.

# Postgres (docker-compose)
POSTGRES_USER=muhasebe
POSTGRES_PASSWORD=change-me
POSTGRES_DB=muhasebe
